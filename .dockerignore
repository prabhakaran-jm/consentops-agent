# Dependencies and build output (rebuilt inside the image)
node_modules
.next

# Git and editor
.git
.gitignore
.cursor

# Local env files — never bake secrets into the image
.env
.env.*
!.env.example

# Tests and docs (not needed at runtime)
tests
coverage
docs

# Misc
README.md
LICENSE

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Copy to terraform.tfvars (gitignored) and fill in values.
# Never commit terraform.tfvars or secret values.

project_id      = "rapid-agent-hackathon-26"
region          = "us-central1"
service_name    = "consentops-agent"

# Build and push first, then set this URI:
# docker build -t REGION-docker.pkg.dev/PROJECT/consentops/consentops-agent:latest .
# docker push REGION-docker.pkg.dev/PROJECT/consentops/consentops-agent:latest
container_image = "us-central1-docker.pkg.dev/rapid-agent-hackathon-26/consentops/consentops-agent:latest"

allow_unauthenticated   = true
max_instances           = 1
create_artifact_registry = true

# Gemini via Secret Manager (two-step — see README.md in this folder):
# enable_gemini_secret = true   # creates secret + IAM
# mount_gemini_secret  = false  # set true after gcloud secrets versions add
enable_gemini_secret = false
mount_gemini_secret  = false
gemini_secret_id     = "GEMINI_API_KEY"
gemini_model         = "gemini-3.5-flash"
